# ============================================================
# Variables de entorno para el suite e2e (Playwright).
# Copiar a `.env` (NO versionado) y completar con cuentas reales
# de prueba entregadas por OATI. El suite hace login REAL contra
# WSO2 — no hay mocks — así que estas credenciales deben
# corresponder a cuentas existentes en los sistemas institucionales
# (terceros_crud/SGA para el egresado, Ágora para la empresa).
# ============================================================

# URLs de los 3 servicios corriendo localmente (ver README de cada repo)
E2E_BASE_URL=http://localhost:4200
E2E_CRUD_URL=http://localhost:8080/v1
E2E_MID_URL=http://localhost:8081/v1

# Credenciales de una cuenta institucional REAL con perfil de egresado
E2E_EGRESADO_USERNAME=
E2E_EGRESADO_PASSWORD=

# Credenciales de una cuenta institucional REAL vinculada a una empresa
# aliada ACTIVA en Ágora (representante de la empresa)
E2E_EMPRESA_USERNAME=
E2E_EMPRESA_PASSWORD=

# Timeout (ms) para el login real contra WSO2 (redirect + formulario +
# callback); súbelo si la red institucional está lenta.
E2E_LOGIN_TIMEOUT=30000
